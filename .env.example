# Combi Tracker — configuration template
# Copy to .env (never committed — see SECURITY.md). Placeholders only; no real values here.

# --- Tier 0 (Cloudflare) ---
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=token-with-pages-and-d1-scope-only
D1_DATABASE_ID=xxxx-xxxx

# --- ingest ---
INGEST_DEVICE_TOKEN_SECRET=random-32-bytes-hex   # HMAC for device tokens
INGEST_RATE_LIMIT_PER_MIN=60

# --- Tier 1 (VPS, when we migrate) ---
# DATABASE_URL=postgres://combi:CHANGE_ME@localhost:5432/combi
# REDIS_URL=redis://localhost:6379
# TRACCAR_URL=http://localhost:8082
# TRACCAR_TOKEN=CHANGE_ME

# --- analytics ---
STATS_TOKEN=long-random-string-for-/system-dashboard
GPS_DEVICES=mauricio-1               # comma-separated allowlist for /api/gps
